<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.oktayosman.ticketcenter.controller.UserDashboardController"
            stylesheets="@../styles.css">

    <top>
        <HBox spacing="10" styleClass="top-bar" alignment="CENTER_LEFT">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Existing Controls (Left) -->
            <Label text="Search:"/>
            <TextField fx:id="searchField" promptText="Search events..." HBox.hgrow="ALWAYS"/>
            <Label text="Genre:"/>
            <ComboBox fx:id="genreFilter" promptText="All Genres"/>

            <Region HBox.hgrow="ALWAYS" />

            <Label fx:id="greetingLabel" text="Hello, {first_name}" />
            <Button fx:id="cartButton" text="🛒 Cart (0)" onAction="#handleCartClick" styleClass="button"/>
            <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout" styleClass="button-logout"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true">
            <content>
                <VBox spacing="20">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Section Header -->
                    <Label text="Upcoming Events" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

                    <TilePane fx:id="eventsTilePane" hgap="20" vgap="20" prefColumns="3">
                        <!-- Event cards will be dynamically generated from the controller at runtime -->
                    </TilePane>
                </VBox>
            </content>
        </ScrollPane>
    </center>

    <!-- Bottom Section: Status Bar -->
    <bottom>
        <HBox alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label text="Welcome to TicketCenter!" styleClass="status-label"/>
        </HBox>
    </bottom>
</BorderPane>